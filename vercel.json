{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install -g pnpm@9 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/toolshub build",
  "outputDirectory": "artifacts/toolshub/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
